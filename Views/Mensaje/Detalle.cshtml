@model IPC2_Proyecto2_202303088.Modelos.Mensaje

<h1>Detalle del Mensaje</h1>

<div style="background-color: #f4f4f9; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
    <p><strong>Nombre:</strong> @Model.Nombre</p>
    <p><strong>Sistema:</strong> @Model.Sistema</p>
    <p><strong>Tiempo Óptimo Calculado:</strong> @ViewBag.TiempoOptimo segundos</p>
    <p><strong>Mensaje Descifrado:</strong> <span style="color: #d9534f; font-weight: bold; font-size: 1.2em;">@ViewBag.MensajeDescifrado</span></p>
</div>

<h2>Instrucciones</h2>
<table border="1" style="border-collapse: collapse; text-align: center; margin-bottom: 20px;">
    <thead style="background-color: #e2efda;">
        <tr>
            <th style="padding: 5px 15px;">Instrucción</th>
        </tr>
    </thead>
    <tbody>
        @{
            var actualInst = Model.Instrucciones.ObtenerCabeza();
            while (actualInst != null)
            {
                var inst = (IPC2_Proyecto2_202303088.Modelos.Instruccion)actualInst.Dato;
                <tr>
                    <td style="padding: 5px 15px; background-color: #f2f2f2;">@inst.Dron,@inst.Altura</td>
                </tr>
                actualInst = actualInst.Siguiente;
            }
        }
    </tbody>
</table>

<h2>Simulación de Tiempo Óptimo</h2>
<div style="overflow-x: auto;">
    <table border="1" style="border-collapse: collapse; text-align: center; width: 100%; max-width: 800px;">
        <thead style="background-color: #e2efda;">
            <tr>
                <th style="padding: 10px;">Tiempo (seg)</th>
                @{
                    var listaDrones = (IPC2_Proyecto2_202303088.Estructuras.ListaDrones)ViewBag.DronesSistema;
                    var nD = listaDrones.ObtenerCabeza();
                    while (nD != null) {
                        var d = (IPC2_Proyecto2_202303088.Modelos.Dron)nD.Dato;
                        <th style="padding: 10px;">@d.Nombre</th>
                        nD = nD.Siguiente;
                    }
                }
            </tr>
        </thead>
        <tbody>
            @{
                var tabla = (IPC2_Proyecto2_202303088.Estructuras.ListaSimple)ViewBag.TablaSimulacion;
                var fila = tabla.ObtenerCabeza();
                while (fila != null) {
                    dynamic datosFila = fila.Dato;
                    <tr>
                        <td style="padding: 8px; font-weight: bold; background-color: #f2f2f2;">@datosFila.Segundo</td>
                        @{
                            var acciones = (IPC2_Proyecto2_202303088.Estructuras.ListaSimple)datosFila.Acciones;
                            var act = acciones.ObtenerCabeza();
                            while (act != null) {
                                dynamic dAct = act.Dato;
                                string colorFondo = dAct.Accion == "Emitir Luz" ? "#fff2cc" : "transparent";
                                <td style="padding: 8px; background-color: @colorFondo;">
                                    @dAct.Accion
                                </td>
                                act = act.Siguiente;
                            }
                        }
                    </tr>
                    fila = fila.Siguiente;
                }
            }
        </tbody>
    </table>
</div>

<br />

<h2>Gráfica de Instrucciones</h2>
@if (ViewBag.RutaImagen != null)
{
    <div style="border: 1px solid #ccc; padding: 10px; margin-bottom: 20px; text-align: center;">
        <img src="@ViewBag.RutaImagen?t=@DateTime.Now.Ticks" alt="Gráfica de Instrucciones" style="max-width: 100%; border: 1px solid black;" />
        <br />
        <small>Ruta detectada: @ViewBag.RutaImagen</small>
    </div>
}

<br />

<a href="/Mensaje">
    <button style="padding: 10px 20px; cursor: pointer;">Volver</button>
</a>