@{ ViewData["Title"] = "Inicio"; }
<div class="text-center">
    <h1 class="display-4">Simulador de Sistemas de Drones</h1>
    <p class="lead mt-4">
        Este software permite la gestión y optimización de mensajes enviados a través de sistemas de drones coordinados.
    </p>
    <div class="row mt-5 text-start">
        <div class="col-md-4">
            <h5>Gestión de Sistemas</h5>
            <p>Visualice la estructura de sus sistemas de drones mediante gráficas generadas con Graphviz.</p>
        </div>
        <div class="col-md-4">
            <h5>Optimización</h5>
            <p>Calcule el tiempo mínimo necesario para que los drones alcancen las alturas requeridas para cada mensaje.</p>
        </div>
        <div class="col-md-4">
            <h5>Reportes XML</h5>
            <p>Genere archivos de salida detallados con el estado segundo a segundo de cada dron en el sistema.</p>
        </div>
    </div>
</div>